{
  "expo": {
    "name": "GuidePlus AI",
    "slug": "guideplusai",
    "version": "1.0.0",
    "scheme": "guideplus",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.vexmechatronics.guideplusai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A6B3C"
      },
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GuidePlus AI to access camera for species identification"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow GuidePlus AI to record audio for translation"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e59dadab-2916-4f0b-aa44-9e9c3d735f15"
      }
    },
    "owner": "ibrahimabdulls-organization"
  }
}
